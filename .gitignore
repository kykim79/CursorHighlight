# XcodeGen이 생성하는 프로젝트 파일 (project.yml에서 재생성됨)
*.xcodeproj

# xcode-build-server config — 사용자별 absolute path 포함, 각자 setup
buildServer.json

# Xcode 빌드 산물
build/
DerivedData/
*.xcuserstate
xcuserdata/

# Swift Package Manager
.build/
Packages/
.swiftpm/

# macOS
.DS_Store

# 개인 도구 설정 (gstack, Claude Code 세션)
.claude/
.gstack/

# 배포 산물
*.app
*.dmg
*.zip

# 임시 / 백업
*.swp
*.tmp
*~

# Demo source files (large originals, not for repo)
docs/screenshots/_source/
